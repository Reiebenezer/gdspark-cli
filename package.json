{
  "name": "gdspark-interpreter",
  "version": "0.1.0",
  "description": "Internal interpreter utilities for running GDSpark command flows in frontend applications.",
  "type": "module",
  "private": false,
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./context": "./src/context.ts",
    "./display": "./src/display.ts",
    "./interpreter": "./src/interpreter.ts",
    "./scenario": "./src/scenario.ts",
    "./utils": "./src/utils.ts"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "gdspark",
    "gds",
    "interpreter",
    "frontend"
  ],
  "license": "MIT",
  "dependencies": {
    "@reiebenezer/gdspark-parser": "^0.1.3",
    "@reiebenezer/ts-utils": "^0.1.6"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
